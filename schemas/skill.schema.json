{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Dynamical-Systems-Research/proprio/schemas/skill.schema.json",
  "title": "Proprio skill catalog entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "instrument", "path", "status", "hardware_qualification_required", "verification"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "instrument": {"type": "string", "minLength": 1},
    "path": {"type": "string", "pattern": "^skills/.+/SKILL\\.md$"},
    "code_path": {"type": ["string", "null"]},
    "status": {"enum": ["reference", "simulation_qualified", "simulation_staged"]},
    "hardware_qualification_required": {"const": true},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "artifact_verdict", "skill_sha256"],
      "properties": {
        "artifact": {"type": "string"},
        "artifact_verdict": {"const": "PASS"},
        "skill_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "code_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "verifier_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "source_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
